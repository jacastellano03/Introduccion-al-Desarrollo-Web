Ejercicio 1: Calculadora de edades

html
<!DOCTYPE html>
<html lang="es">

<head>
    <meta charset="UTF-8">
    <title>Calculadora de Edades</title>
    <link rel="stylesheet" href="style.css">
</head>

<body>

    <div class="contenedor">

        <h1>Calculadora de Edades</h1>

        <label>Nombre</label>
        <input type="text" id="nombre">

        <label>Año de nacimiento</label>
        <input type="number" id="anio">

        <button onclick="calcularEdad()">Calcular edad</button>

        <p id="resultado"></p>

    </div>

    <script>

        function calcularEdad(){

            let nombre = document.getElementById("nombre").value;
            let anio = document.getElementById("anio").value;
            let edad = 2025 - anio;

            if(nombre == ""){

                alert("Ingrese un nombre");

            }

            else if(anio == "" || anio > 2025){

                alert("Ingrese un año válido");

            }

            else{

                document.getElementById("resultado").innerHTML = "Hola " + nombre + ", tienes " + edad + " años.";

            }

        }

    </script>

</body>

</html>

